{
  "permissions": {
    "allow": [
      "PowerShell(node --version)",
      "PowerShell(npm --version)",
      "PowerShell(npm install)",
      "PowerShell(node --check server.js)",
      "PowerShell(node --check main.js)",
      "PowerShell(if \\($?\\) { \"server.js OK\" })",
      "PowerShell(if \\($?\\) { \"main.js OK\" })",
      "PowerShell(npm start)",
      "mcp__visualize__read_me",
      "mcp__visualize__show_widget",
      "PowerShell(gh auth status)",
      "Bash(git init *)",
      "Bash(git add *)",
      "Bash(git commit -m ' *)"
    ]
  }
}
