{
  "name": "pet-chat",
  "version": "0.2.0",
  "description": "상대방의 펫을 내 바탕화면에 띄우고 대화하는 데스크톱 프로그램",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "server": "node server.js",
    "build": "electron-builder --win portable"
  },
  "build": {
    "appId": "com.petchat.app",
    "productName": "PetChat",
    "win": {
      "target": "portable"
    },
    "portable": {
      "artifactName": "PetChat.exe"
    }
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "ws": "^8.18.0"
  }
}
